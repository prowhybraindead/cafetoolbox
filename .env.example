# ============================================
# CafeToolbox - Environment Variables Template
# ============================================
# Use this file as a reference only.
# Copy the LOCAL section into .env.local for development.
# Copy the DEPLOY section into your hosting provider for production.
# NEVER commit .env.local or any file containing real secrets.

# ============================================
# LOCAL
# ============================================
# Use these values when running the apps on your machine.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STATUS_URL=http://localhost:3001

# --- Auth ---
# Cookie domain for local development.
# IMPORTANT: Must be "localhost" (no dot prefix) for dev.
AUTH_COOKIE_DOMAIN=localhost
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=   (optional, inferred from hostname)


# ============================================
# DEPLOY
# ============================================
# Use these values in Vercel or any production host.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://cafetoolbox.app
NEXT_PUBLIC_STATUS_URL=https://status.cafetoolbox.app

# --- Auth ---
# Cookie domain for shared auth across subdomains.
# IMPORTANT: Must be ".cafetoolbox.app" (with leading dot) in production.
# This ensures cookies are shared between cafetoolbox.app and status.cafetoolbox.app.
AUTH_COOKIE_DOMAIN=.cafetoolbox.app
# NEXT_PUBLIC_AUTH_COOKIE_DOMAIN=.cafetoolbox.app

# --- Health Check Cron ---
# HEALTH_CHECK_API_SECRET=your-health-check-secret
# CRON_SECRET=your-cron-secret
