# CafeToolbox Status - Environment Variables Template
# Copy this file to .env.local for local development.
# Use the production values in Vercel or your hosting provider.
# NEVER commit .env.local or any file containing real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- App Config ---
NEXT_PUBLIC_STATUS_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth ---
# Status is public, so this app usually does not need shared auth cookies.
# Keep this only if your shared Supabase utilities require it in your setup.
AUTH_COOKIE_DOMAIN=localhost
