HOST=0.0.0.0
PORT=25914

# Public URLs for hosted deployment (set these in the panel env):
# CNAME / public URL (primary)
CONVERTUBE_PUBLIC_BASE_URL=http://convertube.cafetoolbox.app:25914
CONVERTUBE_HEALTH_URL=http://convertube.cafetoolbox.app:25914/health

# Origin / direct host URL (fallback)
CONVERTUBE_ORIGIN_BASE_URL=http://mbasic7.pikamc.vn:25914
CONVERTUBE_ORIGIN_HEALTH_URL=http://mbasic7.pikamc.vn:25914/health

# Optional extra aliases (comma-separated)
CONVERTUBE_PUBLIC_BASE_URL_ALIASES=http://mbasic7.pikamc.vn:25914

# Dashboard redirect (for unauthenticated page requests)
DASHBOARD_URL=http://localhost:3000

# Cookie security:
# - In production or HTTPS proxy, cookie is forced Secure automatically.
# - Set CONVERTUBE_SECURE_COOKIE=true to force Secure even in non-production.
CONVERTUBE_SECURE_COOKIE=false

# Runtime hardening
MAX_CONCURRENT_JOBS=1
MAX_QUEUE_SIZE=50
JOB_TTL_SECONDS=3600
DOWNLOAD_FILE_TTL_SECONDS=3600
DOWNLOAD_TIMEOUT_SECONDS=300
MAX_JOBS_MEMORY=200
ENABLE_BACKGROUND_CLEANUP=true
BACKGROUND_CLEANUP_INTERVAL_SECONDS=600
# Optional daily cleanup trigger by UTC hour (0-23). Use -1 to disable.
CLEANUP_DAILY_HOUR_UTC=-1

# Optional metadata
CONVERTUBE_VERSION=0.1.0

# Runtime Python dependency install is disabled by default.
# Keep false in production and install dependencies at build time.
CONVERTUBE_AUTO_INSTALL_PY_DEPS=false

# Temporary backward-compat only. Keep false to block query-token transport.
CONVERTUBE_ALLOW_QUERY_TOKEN_FALLBACK=false

# Optional override for yt-dlp binary path/name.
# Leave empty to auto-detect binary or fallback to `python -m yt_dlp`.
YTDLP_BIN=

# Auto-install system deps (ffmpeg) from package manager in bootstrap script.
# Only used by bootstrap-and-run.sh
CONVERTUBE_AUTO_INSTALL_SYSTEM_DEPS=false

# Must match dashboard DASHBOARD_TOOL_SHARED_SECRET
DASHBOARD_TOOL_SHARED_SECRET=replace-with-strong-random-secret
ACCESS_COOKIE_TTL_SECONDS=43200

# If you deploy behind a provider domain+port, set CONVERTUBE_PUBLIC_BASE_URL accordingly.
