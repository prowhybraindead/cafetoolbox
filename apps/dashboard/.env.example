# CafeToolbox Dashboard - Environment Variables Template
# Copy this file to .env.local for local development.
# Use the production values in Vercel or your hosting provider.
# NEVER commit .env.local or any file containing real secrets.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STATUS_URL=http://localhost:3001

# --- Auth ---
AUTH_COOKIE_DOMAIN=localhost

# --- Health Monitoring ---
# Secret token for health check API (POST /api/health-check)
# Generate with: openssl rand -base64 32
HEALTH_CHECK_API_SECRET=dev-secret-12345

# --- External Tool Launch Security ---
# Shared secret used to sign short-lived launch tokens for external tools.
# Must be exactly the same value as DASHBOARD_TOOL_SHARED_SECRET in convertube env.
# Generate with: openssl rand -hex 32
DASHBOARD_TOOL_SHARED_SECRET=dev-dashboard-tool-secret-please-change
# Short-lived access token TTL in seconds (5 minutes recommended).
DASHBOARD_TOOL_TOKEN_TTL_SECONDS=300
# Convertube backend URL used by dashboard API proxy routes.
CONVERTUBE_API_BASE_URL=http://localhost:25914

# Secret token for Vercel Cron authorization
# Must match CRON_SECRET in Vercel environment
CRON_SECRET=dev-cron-secret-12345

# Enable health check features
NEXT_PUBLIC_HEALTH_CHECK_ENABLED=true
