# Required
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Legacy fallback supported (prefer the above going forward):
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Worker loop
MONITORING_INTERVAL_SECONDS=30
MONITORING_MAX_CONCURRENCY=6
MONITORING_WORKER_NAME=monitoring-worker
MONITORING_REQUEST_TIMEOUT_MS=5000
MONITORING_MAX_RETRIES=1
MONITORING_RETRY_DELAY_MS=300

# Incident thresholds
INCIDENT_FAILURE_THRESHOLD=3
INCIDENT_IDENTIFIED_THRESHOLD=5
INCIDENT_MAJOR_THRESHOLD=8
INCIDENT_RECOVERY_THRESHOLD=2
INCIDENT_COOLDOWN_SECONDS=180
HEARTBEAT_LOOKBACK_LIMIT=20

# Logging
# LOG_LEVEL: debug | info | warn | error | critical  (default: info)
LOG_LEVEL=info
# LOG_PRETTY: set to "true" for human-readable output in local dev (default: JSON)
LOG_PRETTY=false

# Optional webhooks
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# Watchdog (runs as separate process: node watchdog.js)
# Threshold: how many seconds of silence before the worker is considered DOWN.
# Defaults to 2x MONITORING_INTERVAL_SECONDS if unset.
WATCHDOG_THRESHOLD_SECONDS=
# How often the watchdog polls the DB for a stale heartbeat (min 30s).
WATCHDOG_CHECK_INTERVAL_SECONDS=60
