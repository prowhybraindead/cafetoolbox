{
  "name": "cafetoolbox",
  "private": true,
  "description": "CafeToolbox",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "clean": "turbo clean",
    "type-check": "turbo type-check",
    "monitoring:start": "node apps/monitoring/main.mjs",
    "monitoring:worker": "node apps/monitoring/worker.mjs",
    "monitoring:once": "node apps/monitoring/worker.mjs --once",
    "monitoring:aggregate-daily": "node apps/monitoring/aggregate-uptime-daily.mjs",
    "monitoring:watchdog": "node apps/monitoring/watchdog.mjs",
    "monitoring:watchdog:once": "node apps/monitoring/watchdog.mjs --once"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=20"
  }
}
